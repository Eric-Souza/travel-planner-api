APP_ENV=development
LOG_LEVEL=INFO

# Default: SQLite (no Docker required)
DATABASE_URL=sqlite+aiosqlite:///./data/travel_planner.db

# PostgreSQL + pgvector (uncomment after: docker compose up -d postgres)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_planner

# Expo dev server origins — replace 192.168.x.x with your PC LAN IP for physical devices
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://192.168.18.5:8081

UPLOADS_DIR=./data/uploads

# Ollama (optional — set USE_MOCK_LLM=false when Ollama is running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
USE_MOCK_LLM=true
