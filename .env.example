APP_ENV=development
LOG_LEVEL=INFO
# PostgreSQL (preferred). Falls back to SQLite if unavailable.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel_planner
# SQLite fallback for dev without Docker:
# DATABASE_URL=sqlite+aiosqlite:///./data/travel_planner.db
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://192.168.1.10:8081
UPLOADS_DIR=./data/uploads
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
USE_MOCK_LLM=true
